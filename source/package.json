{
  "name": "scripts",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "patch-package": "^8.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "postinstall": "patch-package",
    "build": "sh build-with-argos.sh",
    "cli": "bun run cli.ts",
    "test": "bun test",
    "typecheck:cardTemplate": "bun run --cwd modules/cardTemplate typecheck",
    "typecheck:source": "bunx tsc -p tsconfig.json --noEmit",
    "typecheck": "bun run typecheck:source && bun run typecheck:cardTemplate",
    "lint:py": "uvx ruff check modules/wordTranslator",
    "lint": "bun run typecheck && bun run lint:py",
    "template:build": "bun run --cwd modules/cardTemplate build",
    "template:dev": "bun run --cwd modules/cardTemplate dev",
    "template:install": "bun install --cwd modules/cardTemplate",
    "argos:start": "sh -c 'uv run --directory modules/wordTranslator python -m uvicorn main:app --host ${ARGOS_HOST:-0.0.0.0} --port ${ARGOS_PORT:-8000} --reload'",
    "deck:retrieve": "bun run cli.ts retrieve",
    "deck:enrich-translations": "bun run cli.ts enrich-translations",
    "deck:enrich-audio": "bun run cli.ts enrich-audio",
    "deck:build-apkg": "bun run template:build && bun run cli.ts build-apkg",
    "deck:pipeline": "bun run template:build && bun run cli.ts pipeline",
    "deck:build": "bun run deck:pipeline",
    "deck:analyze-ngrams": "bun run modules/deck/analyzeCsvNgrams.ts",
    "sentenceRetrieval:update": "bun run modules/sentenceRetrieval/updateTatoebaLanguages.ts",
    "wordFrequencies:words": "bun run modules/wordFrequencies/updateFrequencyWords.ts"
  },
  "dependencies": {
    "anki-apkg-export": "4.0.3",
    "cac": "^6.7.14",
    "promise-limit": "^2.7.0"
  }
}
