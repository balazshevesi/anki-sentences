{
  "name": "scripts",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "patch-package": "^8.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "postinstall": "patch-package",
    "create": "bun run deck:build",
    "test": "bun test",
    "template:build": "bun run --cwd modules/cardTemplate build",
    "typecheck:scripts": "bunx tsc -p tsconfig.json --noEmit",
    "typecheck:app": "bun run --cwd modules/cardTemplate typecheck",
    "typecheck": "bun run typecheck:scripts && bun run typecheck:app",
    "lint:py": "uvx ruff check modules/wordTranslator",
    "lint": "bun run typecheck && bun run lint:py",
    "deck:build": "bun run app:build && bun run index.ts",
    "update:languages": "bun run modules/sentenceRetrieval/updateTatoebaLanguages.ts",
    "update:words": "bun run modules/wordFrequencies/updateFrequencyWords.ts"
  },
  "dependencies": {
    "anki-apkg-export": "4.0.3"
  }
}
