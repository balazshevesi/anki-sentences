@@ -0,0 +1,51 @@
+export interface CreateTemplateOptions {
+  fields?: string[];
+  questionFormat?: string;
+  answerFormat?: string;
+  css?: string;
+}
+
+export interface AddCardOptions {
+  sortField?: number | string;
+  tags?: string | string[];
+}
+
+export interface SaveOptions {
+  type?: "blob" | "nodebuffer" | "arraybuffer" | "uint8array";
+  base64?: boolean;
+  compression?: "STORE" | "DEFLATE";
+}
+
+export type BinaryData = string | ArrayBuffer | Uint8Array | Blob;
+
+export interface SqlJsLike {
+  Database: new () => {
+    run: (query: string) => void;
+    export: () => Uint8Array;
+    prepare: (query: string) => {
+      getAsObject: (params?: Record<string, unknown>) => Record<string, unknown>;
+    };
+    exec: (query: string) => Array<{ values: unknown[][] }>;
+  };
+}
+
+export interface ExporterConstructorOptions {
+  template: string;
+  sql: SqlJsLike;
+}
+
+export class Exporter {
+  constructor(deckName: string, options: ExporterConstructorOptions);
+  save(options?: SaveOptions): Promise<Blob | ArrayBuffer | Uint8Array>;
+  addMedia(filename: string, data: BinaryData): void;
+  addCard(...fieldsAndMaybeOptions: [...string[], AddCardOptions?]): void;
+}
+
+export interface AnkiExportFactory {
+  (deckName: string, templateOptions?: CreateTemplateOptions): Exporter;
+  new (deckName: string, templateOptions?: CreateTemplateOptions): Exporter;
+}
+
+declare const AnkiExport: AnkiExportFactory;
+
+export default AnkiExport;
